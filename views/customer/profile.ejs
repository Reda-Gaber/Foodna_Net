<%- include('parts/head') %>
<%- include('parts/navbar') %>

<style>
  .profile-container {
    max-width: 800px;
    margin: 40px auto;
    padding: 20px;
  }
  
  .profile-header {
    text-align: center;
    margin-bottom: 30px;
  }
  
  .profile-header h1 {
    color: var(--primary-color);
    margin-bottom: 10px;
  }
  
  .profile-card {
    background: var(--card-bg);
    border-radius: 12px;
    padding: 30px;
    box-shadow: 0 4px 6px rgba(0,0,0,0.1);
  }
  
  .profile-info {
    margin-bottom: 20px;
  }
  
  .profile-info label {
    display: block;
    font-weight: bold;
    margin-bottom: 5px;
    color: var(--text-muted);
  }
  
  .profile-info p {
    font-size: 1.1rem;
    margin: 0;
  }
  
  .btn {
    padding: 10px 20px;
    border-radius: 8px;
    border: none;
    cursor: pointer;
    font-size: 1rem;
    transition: all 0.3s;
  }
  
  .btn-primary {
    background: var(--primary-color);
    color: white;
  }
  
  .btn-danger {
    background: #dc3545;
    color: white;
  }
  
  .profile-actions {
    display: flex;
    gap: 10px;
    margin-top: 20px;
  }
</style>

<div class="profile-container">
  <div class="profile-header">
    <h1>الملف الشخصي</h1>
    <p>مرحباً، <%= user?.name || 'عميل' %></p>
  </div>
  
  <div class="profile-card">
    <div class="profile-info">
      <label>الاسم</label>
      <p><%= user?.name || '-' %></p>
    </div>
    
    <div class="profile-info">
      <label>البريد الإلكتروني</label>
      <p><%= user?.email || '-' %></p>
    </div>
    
    <div class="profile-info">
      <label>نوع الحساب</label>
      <p>عميل</p>
    </div>
    
    <div class="profile-actions">
      <a href="/user/api/update" class="btn btn-primary">تعديل البيانات</a>
      <a href="/user/api/update-password" class="btn btn-primary">تغيير كلمة المرور</a>
      <a href="/auth/logout" class="btn btn-danger">تسجيل الخروج</a>
    </div>
  </div>
</div>

<%- include('parts/footer') %>