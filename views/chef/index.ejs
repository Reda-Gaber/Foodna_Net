  <!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>لوحة المطبخ - Foodna Shob</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"/>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      background: #efefef;
      font-family: 'Tajawal', 'Segoe UI', sans-serif;
      padding: 2rem;
    }

    .header {
      background: linear-gradient(135deg, #ff6b6b 0%, var(--text-color) 100%);
      color: white;
      padding: 2rem;
      border-radius: 12px;
      margin-bottom: 2rem;
      box-shadow: 0 4px 15px rgba(0,0,0,0.1);
      text-align: center;
    }

    .header h1 {
      font-size: 2.5rem;
      font-weight: bold;
      margin-bottom: 0.5rem;
    }

    .header-info {
      font-size: 1rem;
      opacity: 0.95;
    }

    .orders-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(380px, 1fr));
      gap: 2rem;
      margin-bottom: 2rem;
    }

    .order-card {
      background: white;
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 4px 15px rgba(0,0,0,0.1);
      transition: all 0.3s ease;
      border: 3px solid #ff6b6b;
       display: flex;
      flex-direction: column;
      /* position: relative;  */
      
    }

    /* .order-card:hover {
      transform: translateY(-8px);
      box-shadow: 0 12px 30px rgba(0,0,0,0.2);
    } */

    .order-header {
      background: white;
      padding: 1rem 1.2rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-bottom: 2px solid #f0f0f0;
    }

    .order-number {
      font-size: 1.1rem;
      font-weight: bold;
      color: #333;
    }

    .order-time {
      font-size: 0.95rem;
      color: #666;
      font-weight: 500;
    }

    .order-body {
      flex: 1;
      padding: 1.2rem;
      overflow-y: auto;
      max-height: 300px;
    }

    .order-body::-webkit-scrollbar {
      width: 4px;
    }

    .order-body::-webkit-scrollbar-track {
      background: #f1f1f1;
    }

    .order-body::-webkit-scrollbar-thumb {
      background: #ff6b6b;
      border-radius: 2px;
    }

    .items-list {
      list-style: none;
    }

    .item {
      margin-bottom: 1rem;
      padding-bottom: 1rem;
      border-bottom: 1px dashed #e0e0e0;
    }

    .item:last-child {
      border-bottom: none;
      margin-bottom: 0;
      padding-bottom: 0;
    }

    .item-qty {
      font-weight: bold;
      color: #333;
      margin-bottom: 0.3rem;
      font-size: 0.95rem;
    }

    .item-name {
      font-weight: 600;
      color: #333;
      margin-bottom: 0.2rem;
    }

    .item-options {
      font-size: 0.85rem;
      color: #999;
      margin-top: 0.3rem;
    }

    .option-tag {
      display: inline-block;
      background: #f0f0f0;
      padding: 0.2rem 0.6rem;
      border-radius: 4px;
      margin-right: 0.4rem;
      margin-top: 0.2rem;
      font-size: 0.75rem;
    }

    .option-tag.add {
      color: #28a745;
    }

    .option-tag.remove {
      color: #dc3545;
    }

    .option-tag.other {
      color: #6c757d;
    }

    .order-footer {
      padding: 1.2rem;
      border-top: 2px solid #f0f0f0;
      background: #fafafa;
      
       /* margin: 40px; */
    }

    .complete-btn {
      width: 100%;
      background: linear-gradient(135deg, #ff6b6b 0%, var(--text-color) 100%);
      color: white;
      border: none;
      padding: 1rem;
      border-radius: 8px;
      font-weight: bold;
      font-size: 1rem;
      cursor: pointer;
      transition: all 0.3s ease;
      box-shadow: 0 4px 12px rgba(255, 107, 107, 0.3);
      /* position: absolute;
      bottom: 0;
      left: 60;
      /* right: 0; */
      /* position: absolute;
      bottom: 0;
      left: 20px; */ */
     
    }

    .complete-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 16px rgba(255, 107, 107, 0.4);
      background: linear-gradient(135deg, #ff5555 0%, #dd4a42 100%);
    }

    .complete-btn:active {
      transform: translateY(0);
    }

    .no-orders-container {
      text-align: center;
      padding: 4rem 2rem;
      background: white;
      border-radius: 12px;
      box-shadow: 0 4px 15px rgba(0,0,0,0.1);
      grid-column: 1 / -1;
    }

    .no-orders-icon {
      font-size: 4rem;
      color: #ccc;
      margin-bottom: 1rem;
    }

    .no-orders-text {
      font-size: 1.3rem;
      color: #999;
      margin-bottom: 0.5rem;
    }

    .loading-spinner {
      display: inline-block;
      width: 30px;
      height: 30px;
      border: 4px solid #f3f3f3;
      border-top: 4px solid #ff6b6b;
      border-radius: 50%;
      animation: spin 1s linear infinite;
    }

    @keyframes spin {
      0% { transform: rotate(0deg); }
      100% { transform: rotate(360deg); }
    }

    @media (max-width: 768px) {
      .orders-grid {
        grid-template-columns: 1fr;
      }
      .header h1 {
        font-size: 1.8rem;
      }
    }

    .status-indicator {
      display: inline-block;
      width: 10px;
      height: 10px;
      border-radius: 50%;
      margin-left: 0.5rem;
      background: #ffc107;
      animation: pulse 2s infinite;
    }

    @keyframes pulse {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.5; }
    }
    .order-card {
  background: white;
  border-radius: 12px;
  overflow: hidden;
  box-shadow: 0 4px 15px rgba(0,0,0,0.1);
  transition: all 0.3s ease;
  border: 3px solid #ff6b6b;
  display: flex;
  flex-direction: column;
}

.complete-btn {
  width: 100%;
  background: linear-gradient(135deg, #ff6b6b 0%, var(--text-color) 100%);
  color: white;
  border: none;
  padding: 1rem;
  border-radius: 8px;
  font-weight: bold;
  font-size: 1rem;
  cursor: pointer;
  transition: all 0.3s ease;
  box-shadow: 0 4px 12px rgba(255, 107, 107, 0.3);
  margin-top: auto; /* يخلي الزرار في آخر الكارت */
}
  </style>
</head>
<body>
  <!-- Header -->
  <div class="header">
    <h1>
      <i class="fas fa-utensils"></i> مطبخ Foodna Shob
    </h1>
    <div class="header-info">
      <span><i class="fas fa-user"></i> <%= user.name %></span>
      <span style="margin: 0 1rem;">|</span>
      <span><i class="fas fa-clock"></i> <span id="currentTime"></span></span>
    </div>
  </div>

  <!-- Orders Grid (React root) -->
  <div id="chef-root"></div>

  <script src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
  <script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
  <script src="/js/chef.react.js"></script>
</body>
</html>