<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>إيصال - Foodna Shop</title>
    <link rel="stylesheet" href="/css/design-system.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;500;600&family=Montserrat:wght@400;500;600&family=Oswald:wght@400;500;600&display=swap" rel="stylesheet">
    <style>
        @media print {
            body { margin: 0; padding: 20px; }
            .no-print { display: none; }
        }
        
        body {
            background: var(--white-color);
            padding: var(--spacing-xl);
            max-width: 400px;
            margin: 0 auto;
        }
        
        .receipt {
            background: var(--white-color);
            border: 2px solid var(--border-color);
            border-radius: var(--radius-md);
            padding: var(--spacing-lg);
        }
        
        .receipt-header {
            text-align: center;
            border-bottom: 2px solid var(--main-color);
            padding-bottom: var(--spacing-md);
            margin-bottom: var(--spacing-md);
        }
        
        .receipt-header h1 {
            color: var(--main-color);
            margin-bottom: var(--spacing-xs);
        }
        
        .receipt-info {
            margin: var(--spacing-md) 0;
        }
        
        .receipt-info-row {
            display: flex;
            justify-content: space-between;
            margin-bottom: var(--spacing-xs);
        }
        
        .receipt-items {
            margin: var(--spacing-md) 0;
            border-top: 1px dashed var(--border-color);
            border-bottom: 1px dashed var(--border-color);
            padding: var(--spacing-md) 0;
        }
        
        .receipt-item {
            display: flex;
            justify-content: space-between;
            margin-bottom: var(--spacing-sm);
        }
        
        .receipt-total {
            margin-top: var(--spacing-md);
            padding-top: var(--spacing-md);
            border-top: 2px solid var(--main-color);
        }
        
        .receipt-total-row {
            display: flex;
            justify-content: space-between;
            margin-bottom: var(--spacing-sm);
            font-weight: var(--font-medium);
        }
        
        .receipt-total-row.final {
            font-size: var(--h2-font-size);
            font-weight: var(--font-semi-bold);
            color: var(--main-color);
        }
        
        .receipt-footer {
            text-align: center;
            margin-top: var(--spacing-lg);
            padding-top: var(--spacing-md);
            border-top: 1px dashed var(--border-color);
            color: var(--text-color);
            font-size: 0.875rem;
        }
    </style>
</head>
<body>
    <div class="receipt">
        <div class="receipt-header">
            <h1>Foodna Shop</h1>
            <p>نقاط البيع</p>
        </div>

        <div class="receipt-info">
            <div class="receipt-info-row">
                <span>رقم الطلب:</span>
                <strong>#<%= order.Order_ID %></strong>
            </div>
            <div class="receipt-info-row">
                <span>التاريخ:</span>
                <span><%= new Date(order.Created_At).toLocaleString('ar-EG') %></span>
            </div>
            <div class="receipt-info-row">
                <span>طريقة الدفع:</span>
                <span><%= order.Payment_Method === 'cash' ? 'نقدي' : 'بطاقة' %></span>
            </div>
        </div>

        <div class="receipt-items">
            <% items.forEach(item => { %>
                <div class="receipt-item">
                    <div>
                        <div><%= item.Product_Name %></div>
                        <div style="font-size: 0.875rem; color: var(--text-color);">
                            <%= item.Quantity %> × <%= parseFloat(item.Price).toFixed(2) %> جنيه
                        </div>
                    </div>
                    <div>
                        <%= (item.Quantity * parseFloat(item.Price)).toFixed(2) %> جنيه
                    </div>
                </div>
            <% }); %>
        </div>

        <div class="receipt-total">
            <div class="receipt-total-row">
                <span>المجموع الفرعي:</span>
                <span><%= parseFloat(order.Total_Amount).toFixed(2) %> جنيه</span>
            </div>
            <% if (discount && discount > 0) { %>
                <div class="receipt-total-row" style="color: var(--main-color);">
                    <span>الخصم:</span>
                    <span>-<%= discount.toFixed(2) %> جنيه</span>
                </div>
            <% } %>
            <div class="receipt-total-row final">
                <span>الإجمالي:</span>
                <span><%= (parseFloat(order.Total_Amount) - (discount || 0)).toFixed(2) %> جنيه</span>
            </div>
        </div>

        <div class="receipt-footer">
            <p>شكراً لزيارتك!</p>
            <p>Foodna Shop © <%= new Date().getFullYear() %></p>
        </div>
    </div>

    <div class="no-print" style="text-align: center; margin-top: var(--spacing-lg);">
        <button class="btn btn-primary" onclick="window.print()">
            <i class="ri-printer-line"></i> طباعة
        </button>
        <button class="btn btn-secondary" onclick="window.close()" style="margin-right: var(--spacing-sm);">
            إغلاق
        </button>
    </div>
</body>
</html>



